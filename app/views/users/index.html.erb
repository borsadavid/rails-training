<h1> LIST OF USERS </h1>
<ul>
<% @users.each do |user| %>
    <%= link_to "Create a new user", "/users/new" %>
<li>
<%= link_to user.name, user_path(id: user.id) %> - <%= user.email %> - <%= user.birthday %> <%= button_to "Delete", user_path(user), method: :delete %>  </li> 
<% end %>
</ul>
