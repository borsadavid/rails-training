<!DOCTYPE html>
<html>
  <head>
    <title>User Manager | Warm Pro</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
 
    <style>
      body {
        background-color: #FFFAF0 !important; /* FloralWhite */
        font-family: 'Trebuchet MS', sans-serif !important;
        margin: 0 !important;
        display: flex !important;
        justify-content: center !important;
        min-height: 100vh !important;
      }
 
      .app-container {
        background-color: #FFFFFF !important;
        border-top: 10px solid #FF4500 !important; /* OrangeRed */
        border-left: 1px solid #F5DEB3 !important; /* Wheat */
        border-right: 1px solid #F5DEB3 !important; /* Wheat */
        border-bottom: 4px solid #8B4513 !important; /* SaddleBrown */
        border-radius: 8px !important;
        padding: 50px !important;
        width: 100% !important;
        max-width: 750px !important;
        margin: 50px 20px !important;
        box-shadow: 0 15px 35px rgba(139, 69, 19, 0.15) !important;
      }
 
      .flash-notice {
        position: fixed !important;
        top: 25px !important;
        right: 25px !important;
        background-color: #FFA500 !important; /* Orange */
        color: #FFFFFF !important;
        padding: 15px 30px !important;
        border-radius: 4px !important;
        font-weight: bold !important;
        z-index: 10000 !important;
        box-shadow: 5px 5px 0px #8B4513 !important; /* SaddleBrown */
        animation: slideIn 0.3s ease-out !important;
      }
 
      h1, h2, h3 {
        color: #8B4513 !important; /* SaddleBrown */
        text-transform: uppercase !important;
        letter-spacing: 1px !important;
        border-bottom: 2px dashed #FFA500 !important; /* Orange */
        padding-bottom: 10px !important;
      }
 
      .btn-chocolate {
        background-color: #D2691E !important; /* Chocolate */
        color: #FFFFFF !important;
        padding: 12px 24px !important;
        border-radius: 6px !important;
        text-decoration: none !important;
        display: inline-block !important;
        font-weight: bold !important;
        border: none !important;
        cursor: pointer !important;
        transition: background 0.3s !important;
      }
 
      a {
        color: #D2691E !important; /* Chocolate */
        font-weight: bold !important;
        text-decoration: none !important;
      }
 
      a:hover {
        color: #FF4500 !important; /* OrangeRed */
        text-decoration: underline !important;
      }
 
      @keyframes slideIn {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
      }
    </style>
  </head>
 
  <body>
    <% if notice %>
      <div class="flash-notice">
        📙 <%= notice %>
      </div>
    <% end %>
 
    <div class="app-container">
      <%= yield %>
    </div>
  </body>
</html>