<% content_for :title, "Feed Postări | RailsSocial" %>

<div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px dashed #FFA500; padding-bottom: 10px; margin-bottom: 30px;">
  <h1 style="border: none; padding: 0; margin: 0;">Feed Postări</h1>
  <% if user_signed_in? %>
    <%= link_to "➕ Postare Nouă", new_post_path, class: "btn-chocolate" %>
  <% end %>
</div>

<div id="posts" style="max-width: 650px; margin: 0 auto;">
  <%= render @posts %>
</div>