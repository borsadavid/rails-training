<p style="color: green"><%= notice %></p>

<% content_for :title, "Posts" %>

<h1>Feed Postări</h1>

<div id="posts">
  <% @posts.each do |post| %>
    <div style="border: 1px solid #F5DEB3; padding: 20px; margin-bottom: 20px; border-radius: 8px; background-color: white;">
      <%# Afișăm numele celui care a postat %>
      <p><strong><%= post.user.name || post.user.email %></strong> a scris:</p>
      <p><%= post.description %></p>

      <% if post.image.attached? %>
        <div style="text-align: center; margin: 15px 0;">
          <%= image_tag post.image, class: "user-post-image", style: "max-width: 100%; border-radius: 4px;" %>
        </div>
      <% end %>



  <%= turbo_frame_tag "like_post_#{post.id}" do %>
    <div style="margin: 10px 0; display: flex; align-items: center; gap: 10px;">
      <% if user_signed_in? %>
        <% like = post.likes.find_by(user: current_user) %>
        
        <% if like %>
          <%# Buton UNLIKE %>
          <%= button_to post_like_path(post), method: :delete, style: "background: none; border: none; cursor: pointer; font-size: 1.5em; padding: 0;" do %>
            ❤️
          <% end %>
        <% else %>
          <%# Buton LIKE %>
          <%= button_to post_like_path(post), method: :post, style: "background: none; border: none; cursor: pointer; font-size: 1.5em; padding: 0;" do %>
            🤍
          <% end %>
        <% end %>
      <% else %>
        <span style="font-size: 1.5em;">🤍</span>
      <% end %>

      <strong style="color: #555;">
        <%= post.likes.count %> <%= post.likes.count == 1 ? 'Apreciere' : 'Aprecieri' %>
      </strong>
    </div>
  <% end %>

      <div style="margin-top: 20px; padding: 15px; background: #fff8f0; border-radius: 8px;">
        <p><strong>Comentarii:</strong></p>
        
        <div id="comments_post_<%= post.id %>">
          <% post.comments.each do |comment| %>
            <% if comment.persisted? %> 
              <p style="font-size: 0.9em; border-bottom: 1px solid #eee; margin-bottom: 5px; padding-bottom: 5px;">
                <%# Afișăm numele celui care comentează %>
                <strong style="color: #8B4513;"><%= comment.user.name || "Utilizator" %>:</strong> 
                <%= comment.content %>
              </p>
            <% end %>
          <% end %>
        </div>
      
        <% if user_signed_in? %>
          <%= form_with(model: [ post, post.comments.build ], local: true, style: "margin-top: 10px;") do |f| %>
            <div style="display: flex; gap: 10px;">
              <%= f.text_field :content, placeholder: "Adaugă un comentariu...", style: "flex: 1; border-radius: 4px; border: 1px solid #ccc; padding: 5px;" %>
              <%= f.submit "Trimite", style: "background: #8B4513; color: white; border: none; padding: 5px 15px; border-radius: 4px; cursor: pointer;" %>
            </div>
          <% end %>
        <% else %>
          <p style="font-size: 0.8em; color: #666; margin-top: 10px;">
            <%= link_to "Loghează-te", new_user_session_path %> pentru a lăsa un comentariu.
          </p>
        <% end %>
      </div>

      <div style="margin-top: 15px; font-size: 0.9em; color: #666;">
        <%= link_to "Vezi Detalii", post %> 
        
        <%# Doar proprietarul postării vede butoanele de Edit/Delete %> 
        <% if user_signed_in? && post.user == current_user %>
          | <%= link_to "Editează", edit_post_path(post) %>
          | <%= link_to "Șterge", post, data: { turbo_method: :delete, turbo_confirm: "Ești sigur?" }, style: "color: red;" %>
        <% end %>
      </div>
    </div> 
  <% end %>
</div>

<div style="margin-top: 20px;">
  <% if user_signed_in? %>
    <%= link_to "➕ Creează Postare Nouă", new_post_path, class: "btn-chocolate" %>
  <% else %>
    <div style="padding: 15px; background: #eee; border-radius: 8px; text-align: center;">
      <%= link_to "Loghează-te", new_user_session_path %> sau <%= link_to "Înregistrează-te", new_user_registration_path %> pentru a posta.
    </div>
  <% end %>
</div>